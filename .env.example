# ============================================
# Configuration de l'API
# ============================================
API_BASE_URL=https://ai.test.manage.inov-consulting.com

# ============================================
# Environnement
# ============================================
APP_ENV=development

# ============================================
# Timeouts (en secondes)
# ============================================
API_TIMEOUT=30
CHAT_TIMEOUT=60

# ============================================
# Feature Flags
# ============================================
DEBUG_MODE=true
ENABLE_NETWORK_LOGS=true